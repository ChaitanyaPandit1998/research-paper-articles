<mxGraphModel dx="1400" dy="960" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />

    <!-- ══════════════ TITLE ══════════════ -->
    <mxCell id="title" value="&lt;font style='font-size: 20px'&gt;&lt;b&gt;How RoPE Encodes Position in a Transformer&lt;/b&gt;&lt;/font&gt;"
      style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;"
      vertex="1" parent="1">
      <mxGeometry x="300" y="20" width="800" height="50" as="geometry" />
    </mxCell>

    <!-- ══════════════ THE PROBLEM ══════════════ -->
    <mxCell id="problem_bg" value="&lt;b&gt;The Problem with Old Position Encodings&lt;/b&gt;"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffd7d7;strokeColor=#b85450;strokeWidth=2;fontSize=13;verticalAlign=top;"
      vertex="1" parent="1">
      <mxGeometry x="200" y="90" width="1000" height="110" as="geometry" />
    </mxCell>

    <mxCell id="prob1" value="&lt;b&gt;Absolute encoding&lt;/b&gt;&lt;br&gt;Add fixed numbers to embeddings.&lt;br&gt;❌ Can't handle sequences&lt;br&gt;longer than training length."
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=1;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="230" y="130" width="230" height="55" as="geometry" />
    </mxCell>

    <mxCell id="prob2" value="&lt;b&gt;Learned absolute&lt;/b&gt;&lt;br&gt;Learn one embedding per position slot.&lt;br&gt;❌ Hard cap at training length.&lt;br&gt;Longer text? Model is lost."
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=1;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="490" y="130" width="230" height="55" as="geometry" />
    </mxCell>

    <mxCell id="prob3" value="&lt;b&gt;Relative encoding&lt;/b&gt;&lt;br&gt;Modify attention scores by distance.&lt;br&gt;⚠️ Complex to implement.&lt;br&gt;Doesn't always compose well."
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=1;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="750" y="130" width="230" height="55" as="geometry" />
    </mxCell>

    <mxCell id="prob_arrow" value="&lt;b&gt;RoPE solves all of these ↓&lt;/b&gt;"
      style="text;html=1;align=center;fontSize=13;fontStyle=1;strokeColor=none;fillColor=none;"
      vertex="1" parent="1">
      <mxGeometry x="570" y="205" width="260" height="30" as="geometry" />
    </mxCell>

    <!-- ══════════════ ROPE CORE IDEA ══════════════ -->
    <mxCell id="idea_bg" value="&lt;b&gt;RoPE Core Idea: Rotate, Don't Add&lt;/b&gt;"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#e8872a;strokeWidth=2;fontSize=13;verticalAlign=top;"
      vertex="1" parent="1">
      <mxGeometry x="200" y="245" width="1000" height="200" as="geometry" />
    </mxCell>

    <mxCell id="step1" value="&lt;b&gt;Step 1 — Split&lt;/b&gt;&lt;br&gt;&lt;br&gt;Take the Query (Q) or Key (K) vector.&lt;br&gt;Split it into pairs of 2 numbers each.&lt;br&gt;&lt;br&gt;Each pair lives in its own 2D plane&lt;br&gt;and will be rotated independently."
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#e8872a;strokeWidth=2;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="225" y="285" width="260" height="135" as="geometry" />
    </mxCell>

    <mxCell id="step2" value="&lt;b&gt;Step 2 — Assign Rotation Angle&lt;/b&gt;&lt;br&gt;&lt;br&gt;Token at position &lt;b&gt;m&lt;/b&gt;, dimension pair &lt;b&gt;d&lt;/b&gt;:&lt;br&gt;&lt;b&gt;angle = m × θ_d&lt;/b&gt;&lt;br&gt;where θ_d = 10000^(−2d/D)&lt;br&gt;&lt;br&gt;Bigger position = bigger rotation.&lt;br&gt;Early pairs rotate slowly (long-range).&lt;br&gt;Later pairs rotate fast (local detail)."
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#e8872a;strokeWidth=2;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="515" y="285" width="280" height="135" as="geometry" />
    </mxCell>

    <mxCell id="step3" value="&lt;b&gt;Step 3 — Rotate&lt;/b&gt;&lt;br&gt;&lt;br&gt;Apply a 2D rotation to each pair:&lt;br&gt;&lt;br&gt;[x₁, x₂] at position m →&lt;br&gt;[x₁cos(mθ) − x₂sin(mθ),&lt;br&gt; x₁sin(mθ) + x₂cos(mθ)]&lt;br&gt;&lt;br&gt;Standard rotation matrix. No new weights."
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#e8872a;strokeWidth=2;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="825" y="285" width="350" height="135" as="geometry" />
    </mxCell>

    <!-- Step arrows -->
    <mxCell id="sa1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#e8872a;strokeWidth=2;"
      edge="1" source="step1" target="step2" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="sa2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#e8872a;strokeWidth=2;"
      edge="1" source="step2" target="step3" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ══════════════ THE MAGIC ══════════════ -->
    <mxCell id="magic_bg" value="&lt;b&gt;&#x2728; The Magic — Relative Position Falls Out Automatically&lt;/b&gt;"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffde7;strokeColor=#f9a825;strokeWidth=2;fontSize=13;verticalAlign=top;"
      vertex="1" parent="1">
      <mxGeometry x="200" y="465" width="1000" height="145" as="geometry" />
    </mxCell>

    <mxCell id="qm" value="&lt;b&gt;Q at position m&lt;/b&gt;&lt;br&gt;Rotated by angle mθ"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#4a6fa5;strokeWidth=2;fontSize=12;"
      vertex="1" parent="1">
      <mxGeometry x="230" y="505" width="210" height="80" as="geometry" />
    </mxCell>

    <mxCell id="kn" value="&lt;b&gt;K at position n&lt;/b&gt;&lt;br&gt;Rotated by angle nθ"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#4a6fa5;strokeWidth=2;fontSize=12;"
      vertex="1" parent="1">
      <mxGeometry x="470" y="505" width="210" height="80" as="geometry" />
    </mxCell>

    <mxCell id="dot" value="&lt;b&gt;Dot Product&lt;/b&gt;&lt;br&gt;Q_m · K_n"
      style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontSize=12;fontStyle=1;"
      vertex="1" parent="1">
      <mxGeometry x="715" y="505" width="130" height="80" as="geometry" />
    </mxCell>

    <mxCell id="result" value="&lt;b&gt;Result depends only on (m − n)&lt;/b&gt;&lt;br&gt;The absolute positions cancel out!&lt;br&gt;The model sees &lt;i&gt;relative distance&lt;/i&gt; — for free."
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;strokeWidth=2;fontSize=12;"
      vertex="1" parent="1">
      <mxGeometry x="875" y="505" width="300" height="80" as="geometry" />
    </mxCell>

    <mxCell id="me1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#4a6fa5;strokeWidth=2;"
      edge="1" source="qm" target="dot" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="me2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#4a6fa5;strokeWidth=2;"
      edge="1" source="kn" target="dot" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="me3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0288d1;strokeWidth=2;"
      edge="1" source="dot" target="result" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Clock analogy callout -->
    <mxCell id="clock_note" value="&lt;b&gt;Clock analogy:&lt;/b&gt;&lt;br&gt;Token at pos 3 → rotated 3 steps.&lt;br&gt;Token at pos 7 → rotated 7 steps.&lt;br&gt;Compare them → difference = 4 steps.&lt;br&gt;That difference &lt;i&gt;is&lt;/i&gt; the relative position."
      style="shape=callout;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f9a825;strokeWidth=2;fontSize=10;perimeter=calloutPerimeter;size=15;position=0.5;direction=south;"
      vertex="1" parent="1">
      <mxGeometry x="380" y="390" width="240" height="100" as="geometry" />
    </mxCell>

    <!-- ══════════════ KEY PROPERTIES ══════════════ -->
    <mxCell id="props_label" value="&lt;b&gt;&lt;font style='font-size:13px'&gt;Key Properties&lt;/font&gt;&lt;/b&gt;"
      style="text;html=1;align=center;strokeColor=none;fillColor=none;"
      vertex="1" parent="1">
      <mxGeometry x="590" y="625" width="220" height="30" as="geometry" />
    </mxCell>

    <mxCell id="prop1" value="&lt;b&gt;&#x1F4CF; Works beyond training length&lt;/b&gt;&lt;br&gt;&lt;br&gt;Position is an angle, not a slot.&lt;br&gt;Train on 2K tokens →&lt;br&gt;still works at 4K–8K at inference."
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#4caf50;strokeWidth=2;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="200" y="660" width="280" height="110" as="geometry" />
    </mxCell>

    <mxCell id="prop2" value="&lt;b&gt;&#x1F4C9; Long-term decay&lt;/b&gt;&lt;br&gt;&lt;br&gt;Far-apart tokens naturally produce&lt;br&gt;smaller dot products.&lt;br&gt;Model pays less attention to distant&lt;br&gt;tokens — no extra rules needed."
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#4a6fa5;strokeWidth=2;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="560" y="660" width="280" height="110" as="geometry" />
    </mxCell>

    <mxCell id="prop3" value="&lt;b&gt;&#x1F193; Zero extra parameters&lt;/b&gt;&lt;br&gt;&lt;br&gt;RoPE is a pure math transform&lt;br&gt;applied at attention time.&lt;br&gt;No new weights, no embedding tables.&lt;br&gt;Free in terms of model size."
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#805ad5;strokeWidth=2;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="920" y="660" width="280" height="110" as="geometry" />
    </mxCell>

    <!-- ══════════════ ADOPTION ══════════════ -->
    <mxCell id="adoption" value="&lt;b&gt;&#x1F30D; Real-World Adoption — The Standard for Modern LLMs&lt;/b&gt;&lt;br&gt;LLaMA 1/2/3 &amp;nbsp;|&amp;nbsp; Mistral &amp;nbsp;|&amp;nbsp; Falcon &amp;nbsp;|&amp;nbsp; GPT-NeoX &amp;nbsp;|&amp;nbsp; PaLM 2 &amp;nbsp;|&amp;nbsp; Gemma &amp;nbsp;|&amp;nbsp; Qwen&lt;br&gt;Extensions: &lt;b&gt;YaRN&lt;/b&gt; and &lt;b&gt;LongRoPE&lt;/b&gt; stretch context to 128K+ tokens by rescaling the rotation frequencies."
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f7fa;strokeColor=#00838f;strokeWidth=2;fontSize=12;"
      vertex="1" parent="1">
      <mxGeometry x="200" y="800" width="1000" height="80" as="geometry" />
    </mxCell>

  </root>
</mxGraphModel>
