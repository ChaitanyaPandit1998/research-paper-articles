    <mxCell id="l1" value="&lt;b&gt;Layer 1&lt;/b&gt;&lt;br&gt;&lt;b&gt;S&lt;/b&gt;&lt;br&gt;Sliding Window&lt;br&gt;window = n/4&lt;br&gt;Cheap ✅"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#e8872a;strokeWidth=2;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="240" y="480" width="140" height="150" as="geometry" />
    </mxCell>
    <mxCell id="l2" value="&lt;b&gt;Layer 2&lt;/b&gt;&lt;br&gt;&lt;b&gt;S&lt;/b&gt;&lt;br&gt;Sliding Window&lt;br&gt;window = n/4&lt;br&gt;Cheap ✅"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#e8872a;strokeWidth=2;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="410" y="480" width="140" height="150" as="geometry" />
    </mxCell>
    <mxCell id="l3" value="&lt;b&gt;Layer 3&lt;/b&gt;&lt;br&gt;&lt;b&gt;L&lt;/b&gt;&lt;br&gt;Full Attention&lt;br&gt;sees ALL tokens&lt;br&gt;Expensive ⚠️"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#4a6fa5;strokeWidth=2;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="580" y="480" width="140" height="150" as="geometry" />
    </mxCell>
    <mxCell id="l4" value="&lt;b&gt;Layer 4&lt;/b&gt;&lt;br&gt;&lt;b&gt;S&lt;/b&gt;&lt;br&gt;Sliding Window&lt;br&gt;window = n/4&lt;br&gt;Cheap ✅"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#e8872a;strokeWidth=2;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="750" y="480" width="140" height="150" as="geometry" />
    </mxCell>
    <mxCell id="l5" value="&lt;b&gt;Layer 5&lt;/b&gt;&lt;br&gt;&lt;b&gt;S&lt;/b&gt;&lt;br&gt;Sliding Window&lt;br&gt;window = n/4&lt;br&gt;Cheap ✅"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#e8872a;strokeWidth=2;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="920" y="480" width="140" height="150" as="geometry" />
    </mxCell>
    <mxCell id="l6" value="&lt;b&gt;Layer 6&lt;/b&gt;&lt;br&gt;&lt;b&gt;S&lt;/b&gt;&lt;br&gt;Sliding Window&lt;br&gt;window = n/4&lt;br&gt;Cheap ✅"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#e8872a;strokeWidth=2;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="1090" y="480" width="140" height="150" as="geometry" />
    </mxCell>
    <mxCell id="l7" value="&lt;b&gt;Layer 7&lt;/b&gt;&lt;br&gt;&lt;b&gt;L (always)&lt;/b&gt;&lt;br&gt;Full Attention&lt;br&gt;FINAL LAYER&lt;br&gt;always full ⭐"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#4a6fa5;strokeWidth=3;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="1260" y="480" width="140" height="150" as="geometry" />
    </mxCell>

    <!-- Pattern tiling label -->
    <mxCell id="tile_label" value="Pattern 'SSSL' tiles: S S S L | S S S L ..."
