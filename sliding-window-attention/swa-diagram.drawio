      vertex="1" parent="1">
      <mxGeometry x="400" y="640" width="500" height="25" as="geometry" />
    </mxCell>

    <!-- ══════════ BOTTOM: INFORMATION FLOW ══════════ -->
    <mxCell id="flow_bg" value="&lt;b&gt;How 'mat' Learns About 'The cat' — Even Without Direct Attention&lt;/b&gt;"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#805ad5;strokeWidth=2;fontSize=13;verticalAlign=top;"
      vertex="1" parent="1">
      <mxGeometry x="40" y="700" width="1520" height="350" as="geometry" />
    </mxCell>

    <mxCell id="f0" value="&lt;b&gt;Layer 0 (S)&lt;/b&gt;&lt;br&gt;'mat' sees:&lt;br&gt;on, the, mat&lt;br&gt;&lt;br&gt;'the' sees:&lt;br&gt;sat, on, the, mat&lt;br&gt;&lt;br&gt;'mat' knows local&lt;br&gt;neighbourhood only."
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#805ad5;strokeWidth=2;fontSize=10;"
      vertex="1" parent="1">
      <mxGeometry x="65" y="750" width="200" height="265" as="geometry" />
    </mxCell>
    <mxCell id="f1" value="&lt;b&gt;Layer 1 (S)&lt;/b&gt;&lt;br&gt;'mat' sees:&lt;br&gt;on, the, mat&lt;br&gt;&lt;br&gt;'the' now contains&lt;br&gt;info from layer 0:&lt;br&gt;→ it saw 'sat'&lt;br&gt;&lt;br&gt;'mat' indirectly&lt;br&gt;learns about 'sat'&lt;br&gt;via 'the'."
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#805ad5;strokeWidth=2;fontSize=10;"
      vertex="1" parent="1">
      <mxGeometry x="305" y="750" width="200" height="265" as="geometry" />
    </mxCell>
    <mxCell id="f2" value="&lt;b&gt;Layer 2 (S)&lt;/b&gt;&lt;br&gt;'mat' sees:&lt;br&gt;on, the, mat&lt;br&gt;&lt;br&gt;'the' now contains&lt;br&gt;info from layers 0+1:&lt;br&gt;→ it knows about&lt;br&gt;'sat', 'on', 'cat'&lt;br&gt;&lt;br&gt;'mat' now indirectly&lt;br&gt;knows most of the&lt;br&gt;sentence."
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#805ad5;strokeWidth=2;fontSize=10;"
      vertex="1" parent="1">
      <mxGeometry x="545" y="750" width="200" height="265" as="geometry" />
    </mxCell>
    <mxCell id="f3" value="&lt;b&gt;Layer 3 (L) — Full&lt;/b&gt;&lt;br&gt;'mat' DIRECTLY sees:&lt;br&gt;The, cat, sat, on,&lt;br&gt;the, mat&lt;br&gt;&lt;br&gt;All tokens have&lt;br&gt;already exchanged&lt;br&gt;local info.&lt;br&gt;&lt;br&gt;Full context is now&lt;br&gt;woven together.&lt;br&gt;'cat sat on the mat'&lt;br&gt;fully understood. ✅"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#4a6fa5;strokeWidth=3;fontSize=10;"
      vertex="1" parent="1">
      <mxGeometry x="785" y="750" width="200" height="265" as="geometry" />
    </mxCell>

    <!-- flow arrows -->
    <mxCell id="fa1" value="info&lt;br&gt;propagates"
