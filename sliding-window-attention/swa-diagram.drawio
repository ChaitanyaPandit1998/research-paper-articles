      <mxGeometry x="40" y="430" width="1520" height="230" as="geometry" />
    </mxCell>

    <!-- Layer boxes -->
    <mxCell id="l0" value="&lt;b&gt;Layer 0&lt;/b&gt;&lt;br&gt;&lt;b&gt;S&lt;/b&gt;&lt;br&gt;Sliding Window&lt;br&gt;window = n/4&lt;br&gt;Cheap ✅"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#e8872a;strokeWidth=2;fontSize=11;"
