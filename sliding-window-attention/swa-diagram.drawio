<mxGraphModel dx="1400" dy="960" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />

    <!-- TITLE -->
    <mxCell id="title" value="&lt;font style='font-size:20px'&gt;&lt;b&gt;Sliding Window Attention — How It Works&lt;/b&gt;&lt;/font&gt;"
      style="text;html=1;align=center;strokeColor=none;fillColor=none;"
      vertex="1" parent="1">
      <mxGeometry x="350" y="15" width="900" height="45" as="geometry" />
    </mxCell>

    <!-- ══════════ TOP: STANDARD vs SLIDING ══════════ -->

    <!-- Standard Attention box -->
    <mxCell id="std_bg" value="&lt;b&gt;Standard Attention — Every token sees EVERYTHING&lt;/b&gt;"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontSize=12;verticalAlign=top;"
      vertex="1" parent="1">
      <mxGeometry x="40" y="75" width="720" height="320" as="geometry" />
    </mxCell>

    <mxCell id="std_matrix" value="&lt;b&gt;Attention Matrix (6 tokens)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; The  cat  sat  on  the  mat&lt;br&gt;'The'  [ ✓    ✓    ✓    ✓    ✓    ✓ ]&lt;br&gt;'cat'  [ ✓    ✓    ✓    ✓    ✓    ✓ ]&lt;br&gt;'sat'  [ ✓    ✓    ✓    ✓    ✓    ✓ ]&lt;br&gt;'on'   [ ✓    ✓    ✓    ✓    ✓    ✓ ]&lt;br&gt;'the'  [ ✓    ✓    ✓    ✓    ✓    ✓ ]&lt;br&gt;'mat'  [ ✓    ✓    ✓    ✓    ✓    ✓ ]&lt;br&gt;&lt;br&gt;36 comparisons — every ✓ costs compute"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=1;fontSize=11;fontFamily=Courier New;"
      vertex="1" parent="1">
      <mxGeometry x="65" y="120" width="430" height="240" as="geometry" />
    </mxCell>

    <mxCell id="std_cost" value="&lt;b&gt;Compute cost: O(n²)&lt;/b&gt;&lt;br&gt;&lt;br&gt;n=4,096 tokens → 16M ops&lt;br&gt;n=100K tokens → 10B ops ❌"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=1;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="520" y="190" width="210" height="110" as="geometry" />
    </mxCell>

    <!-- Sliding Window Attention box -->
    <mxCell id="swa_bg" value="&lt;b&gt;Sliding Window Attention — Each token sees only NEARBY tokens&lt;/b&gt;"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#38a169;strokeWidth=2;fontSize=12;verticalAlign=top;"
      vertex="1" parent="1">
      <mxGeometry x="840" y="75" width="720" height="320" as="geometry" />
    </mxCell>

    <mxCell id="swa_matrix" value="&lt;b&gt;Attention Matrix (window = 2)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; The  cat  sat  on  the  mat&lt;br&gt;'The'  [ ✓    ✓    ✓    ·    ·    · ]&lt;br&gt;'cat'  [ ✓    ✓    ✓    ✓    ·    · ]&lt;br&gt;'sat'  [ ✓    ✓    ✓    ✓    ✓    · ]&lt;br&gt;'on'   [ ·    ✓    ✓    ✓    ✓    ✓ ]&lt;br&gt;'the'  [ ·    ·    ✓    ✓    ✓    ✓ ]&lt;br&gt;'mat'  [ ·    ·    ·    ✓    ✓    ✓ ]&lt;br&gt;&lt;br&gt;18 comparisons — only the diagonal band"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#38a169;strokeWidth=1;fontSize=11;fontFamily=Courier New;"
      vertex="1" parent="1">
      <mxGeometry x="865" y="120" width="430" height="240" as="geometry" />
    </mxCell>

    <mxCell id="swa_cost" value="&lt;b&gt;Compute cost: O(n × w)&lt;/b&gt;&lt;br&gt;&lt;br&gt;n=100K, w=512:&lt;br&gt;→ 51M ops ✅&lt;br&gt;(200× cheaper than standard)"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#38a169;strokeWidth=1;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="1320" y="190" width="210" height="110" as="geometry" />
    </mxCell>

    <!-- ══════════ MIDDLE: SSSL PATTERN ══════════ -->
    <mxCell id="pattern_bg" value="&lt;b&gt;The window_pattern = &amp;quot;SSSL&amp;quot; — How Layers Are Assigned&lt;/b&gt;"
