      edge="1" source="f2" target="f3" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Summary callout -->
    <mxCell id="summary" value="&lt;b&gt;Key insight:&lt;/b&gt; Local windows in S layers pass info token-by-token through the chain. L layers then stitch the full picture together. Final layer is ALWAYS full (L)."
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f9a825;strokeWidth=2;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="1050" y="820" width="480" height="80" as="geometry" />
    </mxCell>

    <mxCell id="patterns_ref" value="&lt;b&gt;Pattern examples:&lt;/b&gt;&lt;br&gt;'L' → all full (standard)&lt;br&gt;'SSSL' → 3 cheap : 1 full&lt;br&gt;'SSSSL' → 4 cheap : 1 full&lt;br&gt;Final layer always forced to L"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f9a825;strokeWidth=2;fontSize=11;"
      vertex="1" parent="1">
